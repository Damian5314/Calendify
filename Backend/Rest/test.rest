### Admin Management Endpoints

# Get All Users
GET http://localhost:5097/api/v1/admin/users
Cookie: sessionid=your_session_cookie_here
#############
# Get User by ID
GET http://localhost:5097/api/v1/admin/users/1
Cookie: sessionid=your_session_cookie_here
###########
# Create a New User
POST http://localhost:5097/api/v1/admin/users
Content-Type: application/json
Cookie: sessionid=your_session_cookie_here

{
  "firstName": "Jane",
  "lastName": "Doe",
  "email": "janedoe@example.com",
  "password": "password456",
  "role": "User",
  "recuringDays": "Tuesday, Thursday"
}
#########
# Update User#
PUT http://localhost:5097/api/v1/admin/users/1
Content-Type: application/json
Cookie: sessionid=your_session_cookie_here

{
  "firstName": "Jane",
  "lastName": "Smith",
  "email": "janesmith@example.com",
  "password": "newpassword456",
  "role": "Admin",
  "recuringDays": "Friday"
}
###########
# Delete User
DELETE http://localhost:5097/api/v1/admin/users/1
Cookie: sessionid=your_session_cookie_here

