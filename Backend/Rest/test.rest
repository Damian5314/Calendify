### User Authentication Endpoints

# Login
POST http://localhost:5097/api/v1/auth/login
Content-Type: application/json

{
  "email": "user2@example.com",
  "password": "123456"
}
##########
# Register User
POST http://localhost:5097/api/v1/auth/register
Content-Type: application/json

{
  "firstName": "Joohn",
  "lastName": "Doe",
  "email": "joohndoe@example.com",
  "password": "paassword123",
  "recuringDays": "Monday, Wednesday"
}
##############
# Register Admin
POST http://localhost:5097/api/v1/auth/register-admin
Content-Type: application/json

{
  "userName": "admin123",
  "email": "admin@example.com",
  "password": "securepassword"
}
#############
# Get Logged-In User Info
GET http://localhost:5097/api/v1/auth/user-info
Cookie: sessionid=your_session_cookie_here
#########
# Check if User is Logged In
GET http://localhost:5097/api/v1/auth/is-logged-in
Cookie: sessionid=your_session_cookie_here
##########
# Logout
POST http://localhost:5097/api/v1/auth/logout
Cookie: sessionid=your_session_cookie_here

